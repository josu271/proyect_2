{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "npm run test:tdd && npm run test:componentes && npm run test:integracion",
    "test:tdd": "node --test --test-concurrency=1 test/TDD/**/*.test.mjs",
    "test:tdd:cobertura": "node --test --test-concurrency=1 --experimental-test-coverage test/TDD/**/*.test.mjs",
    "test:componentes": "vitest run --maxWorkers=1 test/Componentes/autenticacion/LoginPage.test.jsx test/Componentes/docente/DisponibilidadDocente.test.jsx test/Componentes/estudiante/MiHorarioEstudiante.test.jsx",
    "test:integracion": "vitest run --maxWorkers=1 test/Integracion/autenticacion/login-flujo.test.jsx test/Integracion/docente/disponibilidad-flujo.test.jsx test/Integracion/estudiante/matricula-flujo.test.jsx",
    "test:cobertura": "vitest run --maxWorkers=1 test/Componentes/autenticacion/LoginPage.test.jsx test/Componentes/docente/DisponibilidadDocente.test.jsx test/Componentes/estudiante/MiHorarioEstudiante.test.jsx test/Integracion/autenticacion/login-flujo.test.jsx test/Integracion/docente/disponibilidad-flujo.test.jsx test/Integracion/estudiante/matricula-flujo.test.jsx test/Cobertura/administracion/secciones-ruta.test.jsx test/Cobertura/autenticacion/rutas-criticas.test.jsx test/Cobertura/docente/rutas-criticas.test.jsx test/Cobertura/estudiante/rutas-criticas.test.jsx --coverage",
    "test:cypress:open": "cypress open",
    "test:cypress:run": "cypress run --spec \"test/{Aceptacion,E2E}/**/*.cy.js\"",
    "test:aceptacion": "cypress run --spec \"test/Aceptacion/**/*.cy.js\"",
    "test:e2e": "cypress run --spec \"test/E2E/**/*.cy.js\"",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "cypress": "^13.17.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "vite": "^8.0.12",
    "vitest": "^4.1.9"
  }
}
